---
import Layout from '../layouts/Layout.astro';
import { v4 as uuidv4 } from 'uuid';
import { db } from '../db';
import { users } from '../db/schema';
import { eq } from 'drizzle-orm';

const errorMsg = Astro.url.searchParams.get('error');

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const nickname = data.get('nickname')?.toString();
  const password = data.get('password')?.toString() || '';
  
  const masterPassword = process.env.MASTER_PASSWORD;

  if (masterPassword && password !== masterPassword) {
    return Astro.redirect('/?error=' + encodeURIComponent('Incorrect Master Password'));
  }
  
  if (nickname && nickname.trim() !== '') {
    try {
      const existingUsers = await db.select().from(users).where(eq(users.nickname, nickname.trim())).limit(1);
      let id = '';

      if (existingUsers.length > 0) {
        id = existingUsers[0].id;
        await db.update(users).set({ lastSeen: new Date() }).where(eq(users.id, id));
      } else {
        id = uuidv4();
        await db.insert(users).values({
          id,
          nickname: nickname.trim(),
          lastSeen: new Date(),
          createdAt: new Date(),
        });
      }
      
      Astro.cookies.set('userId', id, { path: '/', httpOnly: true, sameSite: 'lax' });
      if (masterPassword) {
        Astro.cookies.set('auth_token', password, { path: '/', httpOnly: true, sameSite: 'lax' });
      }
      return Astro.redirect('/chat');
    } catch (e: any) {
      console.error("DB INSERT ERROR:", e);
      return new Response("POSTGRES ERROR: " + (e.message || String(e)), { status: 500 });
    }
  }
}
---

<Layout title="Pick Nickname">
  <main class="flex items-center justify-center min-h-screen p-4">
    <div class="bg-slate-800 p-8 rounded-2xl shadow-2xl max-w-md w-full border border-slate-700/60">
      <h1 class="text-3xl font-bold mb-2 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400">Join the Chat</h1>
      <p class="text-slate-400 text-center mb-6">Choose a nickname and enter the master password to jump back in.</p>
      
      {errorMsg && (
        <div class="bg-rose-500/10 border border-rose-500/20 text-rose-400 px-4 py-3 rounded-xl mb-6 text-sm flex items-center gap-3">
          <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
          {errorMsg}
        </div>
      )}
      
      <form method="POST" class="flex flex-col gap-5">
        <div>
          <label for="nickname" class="block text-sm font-medium text-slate-300 mb-1.5 ml-1">Nickname</label>
          <input type="text" id="nickname" name="nickname" required
            class="w-full bg-slate-900 border border-slate-600 rounded-xl px-4 py-3 text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="e.g. Neo">
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-300 mb-1.5 ml-1 flex items-center justify-between">
            <span>Master Password</span>
            <span class="text-xs text-slate-500 font-normal">If configured</span>
          </label>
          <input type="password" id="password" name="password" 
            class="w-full bg-slate-900 border border-slate-600 rounded-xl px-4 py-3 text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            placeholder="••••••••">
        </div>
        <button type="submit"
          class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold tracking-wide py-3.5 px-4 rounded-xl transition shadow-lg relative group mt-3 active:scale-[0.98]">
          <span>Authenticate & Join</span>
        </button>
      </form>
    </div>
  </main>
</Layout>
