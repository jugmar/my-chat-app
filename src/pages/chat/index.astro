---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { rooms, users } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { v4 as uuidv4 } from 'uuid';

const userId = Astro.cookies.get('userId')?.value;
if (!userId) {
  return Astro.redirect('/');
}

const userRows = await db.select().from(users).where(eq(users.id, userId)).limit(1);
if (userRows.length === 0) {
  return Astro.redirect('/');
}
const user = userRows[0];

let allRooms = await db.select().from(rooms);

if (allRooms.length === 0) {
  const lobbyId = uuidv4();
  await db.insert(rooms).values({
    id: lobbyId,
    name: 'Lobby',
    createdAt: new Date(),
  });
  allRooms = await db.select().from(rooms);
}
---

<Layout title="Rooms - Chat">
  <div class="flex flex-col h-screen bg-slate-900 overflow-hidden">
    <header class="h-14 border-b border-slate-700 flex items-center px-4 bg-slate-900 z-10 shrink-0 justify-between shadow-sm">
      <h1 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400 tracking-tight">Rooms Directory</h1>
      <div class="flex items-center gap-3 text-sm text-slate-300">
        <span class="font-medium">{user.nickname}</span>
        <a href="/" class="text-slate-400 hover:text-white transition active:scale-90 bg-slate-800 p-2 rounded-full" title="Sign out">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
        </a>
      </div>
    </header>

    <main class="flex-1 overflow-y-auto p-4 max-w-2xl mx-auto w-full flex flex-col">
      <div class="space-y-3 flex-1 pb-8">
        {allRooms.map((room) => (
          <a href={`/chat/${room.id}`}
             class="flex items-center justify-between p-4 bg-slate-800 rounded-2xl border border-slate-700/60 hover:bg-slate-700/80 hover:border-slate-600 transition shadow-sm active:scale-[0.98]">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400 font-bold text-xl shadow-inner">#</div>
              <span class="text-lg font-semibold text-slate-200 tracking-wide">{room.name}</span>
            </div>
            <div class="flex items-center gap-2 relative z-10" onclick="event.preventDefault(); event.stopPropagation();">
              {room.name.toLowerCase() !== 'lobby' && (
                <button hx-delete={`/api/rooms/${room.id}/delete`} hx-confirm="Are you sure you want to permanently delete this room?" hx-target="closest a" hx-swap="outerHTML swap:0.4s" class="bg-rose-500/10 hover:bg-rose-500/20 text-rose-500 p-2.5 rounded-full transition active:scale-90" title="Delete Room">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                </button>
              )}
              <div class="bg-slate-900/50 p-2.5 rounded-full text-slate-400 pointer-events-none">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-4 border-t border-slate-700/50 pt-6 pb-6 shrink-0">
        <h2 class="text-xs font-bold text-slate-500 mb-4 px-2 uppercase tracking-widest flex items-center gap-2">
          <span>Create New Room</span>
          <div class="h-px bg-slate-700 flex-1"></div>
        </h2>
        <form method="POST" action="/api/rooms/create" class="flex flex-col gap-3 px-2">
          <input type="text" name="name" placeholder="Name your channel..." required
                 class="w-full bg-slate-800/80 border border-slate-600 rounded-2xl px-5 py-4 text-base text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none transition placeholder-slate-500 shadow-sm" />
          <input type="password" name="password" placeholder="Room Password (Optional)..."
                 class="w-full bg-slate-800/80 border border-slate-600 rounded-2xl px-5 py-4 text-base text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none transition placeholder-slate-500 shadow-sm" />
          <button type="submit" class="bg-blue-600 hover:bg-blue-500 rounded-2xl px-5 py-4 text-base font-bold transition shadow-lg w-full active:scale-[0.98] tracking-wide flex items-center justify-center gap-2">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" /></svg>
            Create & Join
          </button>
        </form>
      </div>
    </main>
  </div>
  
  <script is:inline define:vars={{ firstRoomId: allRooms[0]?.id }}>
    function enforceLayout() {
      if (firstRoomId && window.innerWidth >= 768) {
        window.location.replace(`/chat/${firstRoomId}`);
      }
    }
    // Check immediately on load
    enforceLayout();
    // Re-check live as the window scales
    window.addEventListener('resize', enforceLayout);
  </script>
</Layout>
