---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../db';
import { rooms, users, messages } from '../../db/schema';
import { eq, asc } from 'drizzle-orm';

import { getUserColor } from '../../lib/color';

const userId = Astro.cookies.get('userId')?.value;
if (!userId) {
  return Astro.redirect('/');
}

// Fetch user
const userRows = await db.select().from(users).where(eq(users.id, userId)).limit(1);
if (userRows.length === 0) {
  return Astro.redirect('/');
}
const user = userRows[0];

// Fetch rooms
const allRooms = await db.select().from(rooms);
const roomId = Astro.params.roomId;
const currentRoom = allRooms.find(r => r.id === roomId);

if (!currentRoom) {
  return Astro.redirect('/chat');
}

// Fetch messages
const roomMessages = await db
  .select({
    id: messages.id,
    content: messages.content,
    createdAt: messages.createdAt,
    isSystemMessage: messages.isSystemMessage,
    nickname: users.nickname,
    userId: users.id
  })
  .from(messages)
  .leftJoin(users, eq(messages.userId, users.id))
  .where(eq(messages.roomId, currentRoom.id))
  .orderBy(asc(messages.createdAt))
  .limit(100); 
---

<Layout title={`${currentRoom.name} - Chat`}>
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 border-r border-slate-700 flex flex-col hidden md:flex shrink-0">
      <div class="p-4 border-b border-slate-700 h-14 flex items-center">
        <h2 class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400">Rooms</h2>
      </div>
      <div class="flex-1 overflow-y-auto p-2 space-y-1">
        {allRooms.map((room) => (
          <div class="relative group">
            <a href={`/chat/${room.id}`}
               class={`block px-3 py-2 rounded-lg transition pr-10 ${room.id === currentRoom.id ? 'bg-blue-600 text-white shadow-md' : 'text-slate-300 hover:bg-slate-800'}`}>
              # {room.name}
            </a>
            {room.name.toLowerCase() !== 'lobby' && (
              <button hx-delete={`/api/rooms/${room.id}/delete?active=${currentRoom.id}`} hx-confirm="Are you sure you want to permanently delete this room?" hx-target="closest .relative" hx-swap="outerHTML swap:0.4s" class={`absolute right-2 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition p-1.5 rounded-full active:scale-90 ${room.id === currentRoom.id ? 'text-blue-200 hover:text-rose-300 hover:bg-black/20' : 'text-slate-500 hover:text-rose-400 hover:bg-slate-800'}`} title="Delete Room">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              </button>
            )}
          </div>
        ))}
      </div>
      <div class="p-3 border-t border-slate-700">
        <form method="POST" action="/api/rooms/create" class="flex gap-2">
          <input type="text" name="name" placeholder="New room" required
                 class="w-full bg-slate-800 border border-slate-600 rounded px-2 py-1.5 text-sm text-slate-100 focus:ring-1 focus:ring-blue-500 outline-none transition">
          <button type="submit" class="bg-blue-600 hover:bg-blue-700 rounded px-3 py-1.5 text-sm font-semibold transition">+</button>
        </form>
      </div>
      <div class="p-4 border-t border-slate-700 text-sm text-slate-400 flex items-center justify-between">
        <span class="font-medium text-slate-300">{user.nickname}</span>
        <a href="/" class="text-slate-400 hover:text-white transition active:scale-90 bg-slate-800 p-2 rounded-full" title="Sign out & Change Nickname">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
        </a>
      </div>
    </aside>

    <!-- Main Chat Area -->
    <main class="flex-1 flex flex-col bg-slate-800 relative z-0" hx-ext="sse" sse-connect={`/api/rooms/${currentRoom.id}/events`}>
      <header class="h-14 border-b border-slate-700 flex items-center px-2 md:px-4 bg-slate-900/50 backdrop-blur justify-between z-10 shrink-0">
        <div class="flex items-center gap-1 md:gap-3">
          <a href="/chat" class="md:hidden text-blue-400 hover:text-blue-300 p-2 flex items-center transition active:scale-90">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
          </a>
          <h1 class="text-base md:text-lg font-semibold truncate max-w-[150px] md:max-w-none"># {currentRoom.name}</h1>
        </div>
        <div class="flex items-center gap-3 md:gap-4">
          <!-- Sound Toggle -->
          <button id="sound-toggle" class="hidden md:flex text-slate-400 hover:text-slate-200 transition focus:outline-none" title="Toggle Sound">
            <svg id="icon-sound-on" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 hidden">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
            </svg>
            <svg id="icon-sound-off" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75 19.5 12m0 0 2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6 4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
            </svg>
          </button>
          
          <!-- Notification Bell -->
          <div hx-get="/api/notifications" hx-trigger="load, sse:notification_update from:body" hx-ext="sse" sse-connect="/api/events/global" id="notification-bell-container" class="relative active:scale-95 transition">
            <svg class="w-5 h-5 md:w-6 md:h-6 text-slate-400 hover:text-white transition animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
          </div>
          
          <div>
            <div class="flex items-center gap-1.5 md:gap-2 text-xs md:text-sm text-emerald-400 font-medium bg-emerald-500/10 px-2.5 py-1 md:px-3 rounded-full border border-emerald-500/20 shadow-sm" sse-swap="presence">
              <span class="w-1.5 h-1.5 md:w-2 md:h-2 rounded-full bg-emerald-500 animate-pulse"></span>
              <span>1 <span class="hidden md:inline">Online</span></span>
            </div>
          </div>
        </div>
      </header>

      <div class="flex-1 overflow-hidden relative">
        <div class="absolute inset-0 overflow-y-auto p-4 flex flex-col gap-3 pb-8" id="chat-messages" sse-swap="message" hx-swap="beforeend">
          {roomMessages.length > 0 && (
            <div id="history-loader" hx-get={`/api/rooms/${currentRoom.id}/history?before=${roomMessages[0].createdAt.getTime()}`} hx-trigger="intersect once" hx-swap="outerHTML" class="py-2 text-center text-xs text-slate-500">
              Loading older messages...
            </div>
          )}
          {roomMessages.map((msg) => (
            <div class={`flex message-item w-full mb-4 msg-wrapper-${msg.userId} ${msg.userId === user.id ? 'justify-end' : 'justify-start'}`} data-msg-user-id={msg.userId}>
              {msg.isSystemMessage ? (
                <div class="text-xs text-slate-400 italic my-2 bg-slate-900/40 border border-slate-700/50 px-4 py-1.5 rounded-full mx-auto shadow-sm backdrop-blur-sm">{msg.content}</div>
              ) : (
                <>
                  {msg.userId !== user.id && (
                    <div class={`msg-avatar-${msg.userId} w-8 h-8 rounded-full flex items-center justify-center text-white font-bold text-xs shrink-0 mr-2 mt-auto shadow-sm mb-1`} style={`background-color: ${getUserColor(msg.userId)}`}>
                      {msg.nickname ? msg.nickname.charAt(0).toUpperCase() : '?'}
                    </div>
                  )}
                  <div class={`flex flex-col msg-bubble-container-${msg.userId} ${msg.userId === user.id ? 'items-end' : 'items-start'} max-w-[75%]`}>
                    <div class={`rounded-2xl px-4 py-2.5 shadow-sm msg-bubble-${msg.userId} ${msg.userId === user.id ? 'bg-blue-600 text-white rounded-br-sm' : 'bg-slate-700 text-slate-100 rounded-bl-sm border border-slate-600'}`}>
                      {msg.userId !== user.id && <div class={`text-xs text-blue-300 mb-1 font-semibold tracking-wide msg-nickname msg-nickname-${msg.userId}`}>{msg.nickname}</div>}
                      <div class="break-words whitespace-pre-wrap leading-relaxed space-y-2">{msg.content}</div>
                    </div>
                    <div class={`text-[10px] text-slate-500 mt-1 opacity-70 px-1 msg-time ${msg.userId === user.id ? 'text-right tracking-tight' : 'text-left tracking-tight'}`} data-time={msg.createdAt.toISOString()}>
                      {msg.createdAt.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                    </div>
                  </div>
                </>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="p-4 bg-slate-900 border-t border-slate-700 shrink-0 z-10 relative" id="chat-input-container" data-room-id={currentRoom.id}>
        
        <!-- Typing indicator container -->
        <div class="absolute -top-8 left-4 h-8 flex items-center">
          <div sse-swap="typing" hx-swap="innerHTML"></div>
        </div>
        
        <!-- Mention Dropdown -->
        <div id="mention-dropdown" class="absolute bottom-full left-4 mb-2 w-64 bg-slate-800 border border-slate-600 rounded-xl shadow-xl overflow-hidden z-20 hidden text-sm font-medium"></div>

        <form hx-post={`/api/rooms/${currentRoom.id}/messages`} hx-swap="none" class="flex gap-2 max-w-5xl mx-auto items-end"
              onsubmit="setTimeout(() => { this.reset(); this.querySelector('textarea').style.height='auto'; }, 10)">
          <div class="flex-1 bg-slate-800 border border-slate-600 focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500 rounded-2xl overflow-hidden transition duration-200">
            <textarea name="content" required rows="1" id="chat-textarea"
                   hx-post={`/api/rooms/${currentRoom.id}/typing`}
                   hx-trigger="keyup changed delay:2s"
                   hx-swap="none"
                   class="w-full bg-transparent px-4 py-3 text-slate-100 focus:outline-none resize-none min-h-[48px] max-h-32 leading-relaxed"
                   placeholder={`Message #${currentRoom.name}...`}></textarea>
          </div>
          <button type="submit" class="bg-blue-600 hover:bg-blue-500 rounded-xl w-12 h-12 flex items-center justify-center transition shadow-lg shrink-0 outline-none focus:ring-2 focus:ring-blue-400">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 ml-1">
              <path d="M3.478 2.404a.75.75 0 0 0-.926.941l2.432 7.905H13.5a.75.75 0 0 1 0 1.5H4.984l-2.432 7.905a.75.75 0 0 0 .926.94 60.519 60.519 0 0 0 18.445-8.986.75.75 0 0 0 0-1.218A60.517 60.517 0 0 0 3.478 2.404Z" />
            </svg>
          </button>
        </form>
      </div>
    </main>
  </div>
  
    <style define:vars={{ uid: user.id }}>
    .msg-wrapper-var { justify-content: flex-end !important; }
    .msg-bubble-container-var { align-items: flex-end !important; }
    .msg-bubble-var { 
      background-color: #2563eb !important; 
      color: white !important; 
      border: none !important; 
      border-radius: 1rem 1rem 0 1rem !important; 
    }
    .msg-nickname-var { display: none !important; }
    .msg-avatar-var { display: none !important; }
    .msg-time-var { text-align: right !important; }
  </style>

  <script is:inline define:vars={{ uid: user.id }}>
    // We apply the CSS variables dynamically here because Astro's style var injection maps exactly.
    // Instead of using complex build strings, we just manually inject a stylesheet.
    const style = document.createElement('style');
    style.innerHTML = `
      .msg-wrapper-${uid} { justify-content: flex-end !important; }
      .msg-bubble-container-${uid} { align-items: flex-end !important; }
      .msg-bubble-${uid} { background-color: #2563eb !important; color: white !important; border-bottom-left-radius: 1rem !important; border-bottom-right-radius: 0.125rem !important; border:none !important; }
      .msg-nickname-${uid} { display: none !important; }
      .msg-avatar-${uid} { display: none !important; }
      .msg-time-${uid} { text-align: right !important; }
    `;
    document.head.appendChild(style);

    // Auto-scroll to bottom
    const messages = document.getElementById('chat-messages');
    function scrollToBottom() {
      if (messages) messages.scrollTop = messages.scrollHeight;
    }
    scrollToBottom();
    
    // Process server injected HTMX scripts
    document.body.addEventListener('htmx:sseMessage', function(e) {
      setTimeout(scrollToBottom, 50);
      
      // Look for any notification triggers in new messages
      if (e.detail && e.detail.elt) {
        const added = e.detail.elt;
        // Simple client side mention check
        const myNicknameEl = document.querySelector('aside span.font-medium');
        const myNickname = myNicknameEl ? myNicknameEl.innerText.trim().toLowerCase() : '';
      }
    });

    // Handle generic new elements added natively by HTMX swapping
    const observer = new MutationObserver(() => {
      setTimeout(scrollToBottom, 50);
      updateTimestamps();
    });
    if (messages) observer.observe(messages, { childList: true });
    
    // Auto-resize textarea
    const textarea = document.querySelector('textarea');
    if (textarea) {
      textarea.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
      });
    }
    
    // Process server injected HTMX scripts
    document.body.addEventListener('htmx:sseMessage', function(e) {
      setTimeout(scrollToBottom, 50);
      updateTimestamps();
    });

    // --- Relative Timestamps ---
    function updateTimestamps() {
      const now = new Date();
      document.querySelectorAll('.msg-time[data-time]').forEach(el => {
        const time = new Date(el.dataset.time);
        const diffMs = now - time;
        const diffSec = Math.floor(diffMs / 1000);
        const diffMin = Math.floor(diffSec / 60);
        const diffHour = Math.floor(diffMin / 60);
        const diffDay = Math.floor(diffHour / 24);
        
        let text = '';
        if (diffSec < 60) text = 'just now';
        else if (diffMin < 60) text = `${diffMin} min ago`;
        else if (diffHour < 24) {
          const remainingMin = diffMin % 60;
          text = remainingMin > 0 ? `${diffHour}h ${remainingMin}m ago` : `${diffHour}h ago`;
        } else {
          text = `${diffDay}d ago`;
        }
        
        if (el.innerText !== text) {
          el.innerText = text;
        }
      });
    }
    setInterval(updateTimestamps, 30000); // 30 seconds
    updateTimestamps();

    // --- Audio Context and Sound Effects ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    let isSoundMuted = localStorage.getItem('chatMuted') === 'true';
    
    const soundToggle = document.getElementById('sound-toggle');
    const iconOn = document.getElementById('icon-sound-on');
    const iconOff = document.getElementById('icon-sound-off');
    
    function updateSoundIcons() {
      if (isSoundMuted) {
        iconOn.classList.add('hidden');
        iconOff.classList.remove('hidden');
      } else {
        iconOn.classList.remove('hidden');
        iconOff.classList.add('hidden');
      }
    }
    updateSoundIcons();
    
    if (soundToggle) {
      soundToggle.addEventListener('click', () => {
        isSoundMuted = !isSoundMuted;
        localStorage.setItem('chatMuted', isSoundMuted);
        updateSoundIcons();
        if (!isSoundMuted && audioCtx.state === 'suspended') {
          audioCtx.resume();
        }
      });
    }

    window.playSubtlePop = function() {
      if (isSoundMuted) return;
      if (audioCtx.state === 'suspended') audioCtx.resume();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(600, audioCtx.currentTime);
      osc.frequency.exponentialRampToValueAtTime(300, audioCtx.currentTime + 0.1);
      gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + 0.1);
    };

    window.playProminentDing = function() {
      if (isSoundMuted) return;
      if (audioCtx.state === 'suspended') audioCtx.resume();
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(880, audioCtx.currentTime);
      osc.frequency.setValueAtTime(880, audioCtx.currentTime + 0.1);
      osc.frequency.setValueAtTime(1108.73, audioCtx.currentTime + 0.15);
      gain.gain.setValueAtTime(0, audioCtx.currentTime);
      gain.gain.linearRampToValueAtTime(0.2, audioCtx.currentTime + 0.05);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.5);
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start();
      osc.stop(audioCtx.currentTime + 0.5);
    };

    // --- Mentions Logic ---
    const container = document.getElementById('chat-input-container');
    const roomId = container ? container.dataset.roomId : null;
    const mentionTextarea = document.getElementById('chat-textarea');
    const dropdown = document.getElementById('mention-dropdown');
    
    let onlineUsers = [];
    let mentionQuery = '';
    let inMentionMode = false;
    let selectionIndex = 0;
    
    async function fetchOnlineUsers() {
      if (!roomId) return;
      try {
        const res = await fetch(`/api/rooms/${roomId}/online`);
        onlineUsers = await res.json();
      } catch(e) {}
    }
    
    function renderDropdown() {
      if (!inMentionMode) return;
      
      const filtered = [{ id: 'all', nickname: 'everyone' }];
      for (const u of onlineUsers) {
        if (u.nickname.toLowerCase().includes(mentionQuery)) {
          filtered.push(u);
        }
      }
      
      if (filtered.length === 0) {
        dropdown.style.display = 'none';
        return;
      }
      
      selectionIndex = Math.min(selectionIndex, filtered.length - 1);
      
      dropdown.innerHTML = filtered.map((u, i) => `
        <div class="px-4 py-2 cursor-pointer transition ${i === selectionIndex ? 'bg-blue-600 text-white' : 'text-slate-300 hover:bg-slate-700'}" data-index="${i}" data-name="${u.nickname}">
          @${u.nickname}
        </div>
      `).join('');
      
      dropdown.style.display = 'block';
    }
    
    function insertMention(name) {
      const val = mentionTextarea.value;
      const cursor = mentionTextarea.selectionStart;
      const textBeforeCursor = val.slice(0, cursor);
      const textAfterCursor = val.slice(cursor);
      const replaceStart = textBeforeCursor.lastIndexOf('@');
      
      if (replaceStart !== -1) {
        const newVal = val.slice(0, replaceStart) + '@' + name + ' ' + textAfterCursor;
        mentionTextarea.value = newVal;
        
        const newCursorPos = replaceStart + name.length + 2;
        setTimeout(() => {
          mentionTextarea.setSelectionRange(newCursorPos, newCursorPos);
          mentionTextarea.focus();
        }, 10);
      }
      
      inMentionMode = false;
      dropdown.style.display = 'none';
    }
    
    if (mentionTextarea && dropdown) {
      mentionTextarea.addEventListener('input', (e) => {
        const val = mentionTextarea.value;
        const cursor = mentionTextarea.selectionStart;
        const textBeforeCursor = val.slice(0, cursor);
        const match = textBeforeCursor.match(/(?:^|\\s)@(\\w*)$/);
        
        if (match) {
          if (!inMentionMode) {
            selectionIndex = 0;
            fetchOnlineUsers();
          }
          inMentionMode = true;
          mentionQuery = match[1].toLowerCase();
          renderDropdown();
        } else {
          inMentionMode = false;
          dropdown.style.display = 'none';
        }
      });
      
      mentionTextarea.addEventListener('keydown', (e) => {
        if (inMentionMode && dropdown.style.display !== 'none') {
          const items = dropdown.children;
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            selectionIndex = (selectionIndex + 1) % items.length;
            renderDropdown();
            return;
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            selectionIndex = (selectionIndex - 1 + items.length) % items.length;
            renderDropdown();
            return;
          } else if (e.key === 'Enter' || e.key === 'Tab') {
            e.preventDefault();
            const selectedName = items[selectionIndex].dataset.name;
            insertMention(selectedName);
            return;
          } else if (e.key === 'Escape') {
            inMentionMode = false;
            dropdown.style.display = 'none';
            return;
          }
        }
        
        if (e.key === 'Enter' && !e.shiftKey) {
          if (inMentionMode && dropdown.style.display !== 'none') {
            e.preventDefault();
            const items = dropdown.children;
            const selectedName = items[selectionIndex].dataset.name;
            insertMention(selectedName);
            return;
          }
          
          e.preventDefault();
          // Let htmx know we want to fire the post payload natively via htmx AJAX
          mentionTextarea.form.dispatchEvent(new Event('submit', {cancelable: true, bubbles: true}));
        }
      });
      
      dropdown.addEventListener('click', (e) => {
        const item = e.target.closest('[data-name]');
        if (item) insertMention(item.dataset.name);
      });
    }
    
    // Ask for Notification permission on load
    if (window.Notification && Notification.permission !== "granted" && Notification.permission !== "denied") {
      setTimeout(() => Notification.requestPermission(), 2000);
    }
  </script>
</Layout>
