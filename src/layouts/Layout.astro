---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- HTMX and SSE Extension -->
		<script is:inline src="https://unpkg.com/htmx.org@1.9.11"></script>
		<script is:inline src="https://unpkg.com/htmx.org@1.9.11/dist/ext/sse.js"></script>
	</head>
	<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col font-sans antialiased">
		<slot />
	</body>
</html>
